{
  "name": "AWS Lambda",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "dev",
  "workspaceFolder": "/app",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },
  "containerEnv": {
    // /home/vscode/.local/share/mise/shims: Enables mise managed tools (aws, terraform, etc.)
    // /usr/local/...: Standard paths. To update this list 'docker run --rm [image] env | grep PATH'
    "PATH": "/home/vscode/.local/share/mise/shims:/usr/local/py-utils/bin:/usr/local/python/current/bin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "mermaidchart.vscode-mermaid-chart",
        "amazonwebservices.aws-toolkit-vscode"
      ]
    }
  },
  "postCreateCommand": "scripts/setup-mve.sh && scripts/terraform/deploy.sh"
}