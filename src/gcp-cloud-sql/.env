# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mve_db
DB_HOST=localhost
DB_PORT=5432

# SQLAlchemy Connection URI
# Localhost works due to --network=host or host.docker.internal depending on setups.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mve_db

# Firebase Emulator Config
STORAGE_BUCKET=mve-gcp-cloud-sql.appspot.com
FIREBASE_STORAGE_EMULATOR_HOST="localhost:9199"
FIREBASE_FUNCTIONS_EMULATOR_HOST="localhost:5001"
GCP_PROJECT=mve-gcp-cloud-sql
