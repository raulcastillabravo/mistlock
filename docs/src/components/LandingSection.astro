---
interface Props {
  alt?: boolean;
  centered?: boolean;
}

const { alt = false, centered = false } = Astro.props;
---

<section
  class:list={[
    "not-content",
    "section",
    { "section--alt": alt, "section--centered": centered },
  ]}
  data-landing-section
>
  <div class="section__inner py-16 px-4">
    <slot />
  </div>
</section>

<style>
  .section--alt {
    width: 100vw;
    position: relative;
    left: 50%;
    margin-left: -50vw;
    background-color: rgb(0 0 0 / 0.04);
  }

  :global([data-theme="dark"]) .section--alt {
    background-color: rgb(255 255 255 / 0.04);
  }

  .section__inner {
    max-width: var(--sl-content-width, 72rem);
    margin-inline: auto;
  }

  :global(.section--centered .section__inner > h2),
  :global(.section--centered .section__inner > p) {
    text-align: center;
    margin-inline: auto;
  }

  :global(.section .section__inner > h2) {
    font-size: var(--sl-text-h2);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  :global(.section .section__inner > p) {
    max-width: 60ch;
    color: var(--sl-color-gray-2);
    margin-bottom: 2rem;
  }

  :global(.section .section__inner > h2),
  :global(.section .section__inner > p) {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.5s ease-out var(--entrance-delay, 0ms),
      transform 0.5s ease-out var(--entrance-delay, 0ms);
  }

  :global(.section .section__inner > h2.is-visible),
  :global(.section .section__inner > p.is-visible) {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.section .section__inner > h2),
    :global(.section .section__inner > p) {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { observeEntrance } from "../utils/observer";

  function init() {
    document.querySelectorAll("[data-landing-section]").forEach((section) => {
      const inner = section.querySelector(".section__inner");
      if (!inner) return;
      const targets = inner.querySelectorAll(":scope > h2, :scope > p");
      targets.forEach((el, i) => {
        (el as HTMLElement).style.setProperty("--entrance-delay", `${i * 80}ms`);
      });
      observeEntrance(":scope > h2, :scope > p", 0.15, inner);
    });
  }

  document.addEventListener("astro:page-load", init);
  init();
</script>
