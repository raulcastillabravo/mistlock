---
import Default from '@astrojs/starlight/components/Head.astro';

const { entry, id, lang, lastUpdated, siteTitle } = Astro.locals.starlightRoute;

const ogImage = new URL('/og/default-og.png', Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site);
const isSpanish = lang === 'es';
const isHome = id === '' || id === 'es';
const isLab = entry.data.isLab === true;

const author = {
    '@type': 'Person',
    name: 'Raúl Castilla Bravo',
    sameAs: 'https://www.linkedin.com/in/raulcastillabravo/',
};

const schemas = [];

if (isHome) {
    schemas.push({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: siteTitle,
        url: Astro.site?.href,
        description: entry.data.description,
        inLanguage: lang,
        author,
    });
}

if (isLab) {
    schemas.push({
        '@context': 'https://schema.org',
        '@type': 'TechArticle',
        headline: entry.data.title,
        description: entry.data.description,
        url: canonical.href,
        inLanguage: lang,
        image: ogImage.href,
        author,
        publisher: author,
        ...(lastUpdated && { dateModified: lastUpdated.toISOString() }),
    });
}

if (!isHome) {
    const homeUrl = new URL(isSpanish ? '/es/' : '/', Astro.site);
    const catalogUrl = new URL(
        isSpanish ? '/es/start-here/catalog/' : '/start-here/catalog/',
        Astro.site,
    );
    const crumbs = [
        { name: isSpanish ? 'Inicio' : 'Home', item: homeUrl.href },
        ...(isLab
            ? [{ name: isSpanish ? 'Catálogo' : 'Catalog', item: catalogUrl.href }]
            : []),
        { name: entry.data.title },
    ];
    schemas.push({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((crumb, index) => ({
            '@type': 'ListItem',
            position: index + 1,
            ...crumb,
        })),
    });
}
---

<Default />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:image" content={ogImage} />
{schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
