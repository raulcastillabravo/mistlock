---
interface Props {
  emoji: string;
  title: string;
  description: string;
  delay?: number;
}

const { emoji, title, description, delay = 0 } = Astro.props;
---

<div
  class="not-content feature-card rounded-xl border border-gray-200 dark:border-slate-700/50 overflow-hidden flex flex-col h-full"
  style={`--entrance-delay: ${delay}ms`}
  data-feature-card
>
  <div class="flex items-center gap-3 px-5 py-4">
    <span class="text-2xl leading-none">{emoji}</span>
    <h3 class="text-base font-bold text-gray-900 dark:text-white m-0">{title}</h3>
  </div>
  <hr class="border-t border-gray-200 dark:border-slate-700/50 m-0" />
  <div class="px-5 py-4 flex-1">
    <p class="text-sm text-gray-600 dark:text-slate-400 m-0">{description}</p>
  </div>
</div>

<style>
  .feature-card {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.5s ease-out var(--entrance-delay, 0ms),
      transform 0.5s ease-out var(--entrance-delay, 0ms),
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .feature-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .feature-card.is-visible:hover {
    transform: translateY(-4px);
    border-color: rgb(167 139 250 / 0.7);
    background-color: rgb(249 250 251);
    box-shadow: 0 8px 24px rgb(139 92 246 / 0.12);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  :global([data-theme='dark']) .feature-card.is-visible:hover {
    border-color: rgb(139 92 246 / 0.45);
    background-color: rgb(30 41 59 / 0.6);
    box-shadow: 0 8px 24px rgb(139 92 246 / 0.1);
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { observeEntrance } from '../utils/observer';
  observeEntrance('[data-feature-card]');
</script>
