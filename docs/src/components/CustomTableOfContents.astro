---
import DefaultTableOfContents from "@astrojs/starlight/components/TableOfContents.astro";
import { getLabPageData } from "../utils/labPage";
import LabActions from "./LabActions.astro";

const { id, entry } = Astro.locals.starlightRoute;
const { isLabPage, zipUrl, githubUrl, btnDownloadText, btnGithubText } =
  getLabPageData(id, entry);
---

<DefaultTableOfContents {...Astro.props}><slot /></DefaultTableOfContents>

{
  isLabPage && (
    <div class="toc-actions">
      <LabActions
        zipUrl={zipUrl}
        githubUrl={githubUrl}
        btnDownloadText={btnDownloadText}
        btnGithubText={btnGithubText}
        variant="sidebar"
      />
    </div>
  )
}

<style>
  .toc-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
    border-top: 1px solid var(--sl-color-hairline);
    padding-top: 1.5rem;
  }
</style>
