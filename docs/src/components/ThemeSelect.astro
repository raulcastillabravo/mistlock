---

---

<starlight-theme-toggle>
	<button type="button" aria-label="Toggle color theme">
		<svg
			class="moon"
			xmlns="http://www.w3.org/2000/svg"
			width="18"
			height="18"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
		</svg>
		<svg
			class="sun"
			xmlns="http://www.w3.org/2000/svg"
			width="18"
			height="18"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<circle cx="12" cy="12" r="5"></circle>
			<path
				d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
			></path>
		</svg>
	</button>
</starlight-theme-toggle>

<style>
	starlight-theme-toggle {
		display: flex;
		align-items: center;
	}

	button {
		background: none;
		border: 1px solid transparent;
		cursor: pointer;
		padding: 0.375rem;
		color: var(--sl-color-gray-1);
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			color 0.2s ease;
	}

	button:hover {
		color: var(--sl-color-white);
		background-color: var(--sl-color-gray-6);
		border-color: var(--sl-color-gray-4);
	}

	.sun {
		display: none;
	}

	:global([data-theme="light"]) .sun {
		display: block;
	}

	:global([data-theme="light"]) .moon {
		display: none;
	}
</style>

<script>
	class StarlightThemeToggle extends HTMLElement {
		connectedCallback() {
			this.querySelector("button")?.addEventListener("click", () => {
				const isDark =
					document.documentElement.getAttribute("data-theme") !== "light";
				const next = isDark ? "light" : "dark";
				document.documentElement.setAttribute("data-theme", next);
				localStorage.setItem("starlight-theme", next);
			});
		}
	}

	customElements.define("starlight-theme-toggle", StarlightThemeToggle);
</script>
