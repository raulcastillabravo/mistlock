---
import { Icon } from 'astro-icon/components';

interface Service {
  icon: string;
  title: string;
  description: string;
  comingSoon?: boolean;
}

interface Props {
  services: Service[];
}

const { services } = Astro.props;

const isIconify = (icon: string) => icon.includes(':');
---

<div class="not-content grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-6 items-stretch">
  {services.map((service, i) => (
    service.comingSoon ? (
      <div
        class="provider-card provider-card--soon border border-dashed border-gray-200 dark:border-slate-700/30 rounded-xl p-5 bg-gray-50/40 dark:bg-slate-900/20 select-none"
        style={`--entrance-delay: ${(i % 3) * 100}ms`}
        data-provider-card
      >
        <div class="mb-3 grayscale">
          {isIconify(service.icon)
            ? <Icon name={service.icon} class="w-8 h-8" />
            : <span class="text-2xl">{service.icon}</span>
          }
        </div>
        <div class="flex items-center gap-2 mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">{service.title}</h3>
          <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-gray-200 dark:bg-slate-700 text-gray-500 dark:text-slate-400 shrink-0">soon</span>
        </div>
        <p class="text-sm text-gray-500 dark:text-slate-500 line-clamp-2">{service.description}</p>
      </div>
    ) : (
      <div
        class="provider-card border border-gray-200 dark:border-slate-700/50 rounded-xl p-5 bg-gray-50 dark:bg-slate-900/40"
        style={`--entrance-delay: ${(i % 3) * 100}ms`}
        data-provider-card
      >
        <div class="mb-3">
          {isIconify(service.icon)
            ? <Icon name={service.icon} class="w-8 h-8" />
            : <span class="text-2xl">{service.icon}</span>
          }
        </div>
        <h3 class="font-semibold text-gray-900 dark:text-white mb-2">{service.title}</h3>
        <p class="text-sm text-gray-600 dark:text-slate-400 line-clamp-2">{service.description}</p>
      </div>
    )
  ))}
</div>

<style>
  .provider-card {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.5s ease-out var(--entrance-delay, 0ms),
      transform 0.5s ease-out var(--entrance-delay, 0ms),
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .provider-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .provider-card--soon.is-visible {
    opacity: 0.5;
  }

  .provider-card.is-visible:not(.provider-card--soon):hover {
    transform: translateY(-4px);
    border-color: rgb(167 139 250 / 0.7);
    background-color: var(--sl-color-bg-nav);
    box-shadow: 0 8px 24px rgb(139 92 246 / 0.12);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  :global([data-theme='dark']) .provider-card.is-visible:not(.provider-card--soon):hover {
    border-color: rgb(139 92 246 / 0.45);
    background-color: rgb(30 41 59 / 0.6);
    box-shadow: 0 8px 24px rgb(139 92 246 / 0.1);
  }

  @media (prefers-reduced-motion: reduce) {
    .provider-card {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { observeEntrance } from '../utils/observer';
  observeEntrance('[data-provider-card]');
</script>
