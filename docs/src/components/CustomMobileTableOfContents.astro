---
import DefaultMobileTableOfContents from "@astrojs/starlight/components/MobileTableOfContents.astro";
import { Icon } from "@astrojs/starlight/components";
import { siteConfig } from "../config";

const { id, toc, entry } = Astro.locals.starlightRoute;
const isEs = id.startsWith("es/");
const cleanId = id.replace(/^es\//, "");
const pathParts = cleanId.split("/");

const isExamplePage = !!entry.data.isExample;

let zipUrl = "";
let githubUrl = "";
if (isExamplePage) {
  zipUrl = `/${siteConfig.repositoryName}/downloads/${pathParts.join("-")}.zip`;
  githubUrl = `${siteConfig.githubUrl}/tree/main/src/${cleanId}`;
}

const btnDownloadText = isEs ? "Descargar código" : "Download code";
const btnGithubText = isEs ? "Ver en GitHub" : "View on GitHub";
---

<DefaultMobileTableOfContents {...Astro.props}><slot /></DefaultMobileTableOfContents>

{
  toc && isExamplePage && (
    <div class="mobile-toc-actions">
      <a
        href={zipUrl}
        class="mobile-action-btn mobile-download-btn"
        download
        title={btnDownloadText}
      >
        <Icon name="download" size="1.1rem" />
      </a>
      <a
        href={githubUrl}
        class="mobile-action-btn mobile-github-btn"
        target="_blank"
        rel="noopener noreferrer"
        title={btnGithubText}
      >
        <Icon name="github" size="1.1rem" />
      </a>
    </div>
  )
}

<style>
  .mobile-toc-actions {
    position: fixed;
    z-index: var(--sl-z-index-toc);
    /* Mobile TOC bar is positioned just below sl-nav-height */
    /* We align the buttons inside that space */
    top: calc(var(--sl-nav-height) + 0.35rem);
    right: 1rem;
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .mobile-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    background-color: transparent;
  }

  .mobile-download-btn {
    color: var(--sl-color-text-accent) !important;
  }

  .mobile-download-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--sl-color-white) !important;
  }

  .mobile-github-btn {
    color: var(--sl-color-gray-2) !important;
  }

  .mobile-github-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--sl-color-white) !important;
  }

  /* Light theme styling */
  :global([data-theme=light]) .mobile-toc-actions .mobile-download-btn:hover {
    background-color: rgba(0, 0, 0, 0.05) !important;
    color: var(--sl-color-text-accent) !important;
  }

  :global([data-theme=light]) .mobile-toc-actions .mobile-github-btn {
    color: var(--sl-color-gray-2) !important;
  }

  :global([data-theme=light]) .mobile-toc-actions .mobile-github-btn:hover {
    background-color: rgba(0, 0, 0, 0.05) !important;
    color: var(--sl-color-black) !important;
  }

  /* Make sure the text in mobile-starlight-toc does not overlap our buttons */
  :global(mobile-starlight-toc summary) {
    padding-inline-end: 6.5rem !important;
  }

  /* Support RTL direction */
  :global([dir="rtl"]) .mobile-toc-actions {
    right: auto;
    left: 1rem;
  }

  :global([dir="rtl"]) :global(mobile-starlight-toc summary) {
    padding-inline-start: 6.5rem !important;
    padding-inline-end: 1rem !important;
  }

  /* Light theme styling */
  :global([data-theme="light"]) .mobile-github-btn {
    background-color: var(--sl-color-gray-2);
    color: var(--sl-color-black) !important;
    border-color: var(--sl-color-gray-3);
  }

  :global([data-theme="light"]) .mobile-github-btn:hover {
    background-color: var(--sl-color-gray-1);
    color: var(--sl-color-black) !important;
  }
</style>
